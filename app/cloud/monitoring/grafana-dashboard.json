{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Fire Detection Map",
      "type": "geomap",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "basemap": { "config": {}, "name": "Layer 0", "type": "default" },
        "controls": { "mouseWheelZoom": true, "showScale": true, "showZoom": true },
        "layers": [
          {
            "config": {
              "showLegend": true,
              "style": {
                "color": { "field": "Value", "fixed": "dark-green" },
                "opacity": 0.8,
                "size": { "field": "Value", "fixed": 10, "max": 20, "min": 5 },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" }
              }
            },
            "location": { "latitude": "lat", "longitude": "lon", "mode": "fields" },
            "name": "Fire Detections",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "tooltip": { "mode": "details" },
        "view": { "id": "coords", "lat": 11.5, "lon": 107.5, "zoom": 7 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "fire_detection_confidence",
          "format": "table",
          "instant": true,
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.5 },
                { "color": "orange", "value": 0.7 },
                { "color": "red", "value": 0.8 }
              ]}}
            ]
          }
        ]
      }
    },
    {
      "title": "Detection Rate by Location",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(fire_detection_total{result=\"fire\"}[1m])",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 } },
        "overrides": []
      }
    },
    {
      "title": "Inference Latency p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(fire_detection_latency_seconds_bucket[5m]))",
          "legendFormat": "{{location}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Total Fire Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(fire_detection_total{result=\"fire\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 10 }] } } }
    },
    {
      "title": "Active Locations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "count(fire_detection_confidence)", "refId": "A" }]
    },
    {
      "title": "Inference Pods",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "count(up{job=\"fire-detection\"})", "refId": "A" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["fire-detection", "edge-ai"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "Fire Detection - Edge AI",
  "uid": "fire-detection-map"
}
